# Environment Configuration
# Copy this file and rename to .env

# ── OpenAI API Key (required for resume generation) ──
OPENAI_API_KEY=sk-your-openai-key-here

# ── Stripe Keys (required for payments) ──
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Optional: Set these if you created products in Stripe Dashboard
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_LIFETIME_PRICE_ID=price_xxx

# ── App Config ──
SECRET_KEY=change-this-to-a-random-secret-string
DOMAIN=https://your-domain.com  # Your production URL
